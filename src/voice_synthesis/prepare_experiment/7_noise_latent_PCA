{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"gpuType":"T4","mount_file_id":"16Mq0gU6QEqQ4pO-CZYUbs4uShiI7bUwz","authorship_tag":"ABX9TyPYIUQBZDOjjjRsY6BLm+vn"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"},"accelerator":"GPU"},"cells":[{"cell_type":"markdown","source":["## 各種設定"],"metadata":{"id":"D5U2J0XxPD3w"}},{"cell_type":"code","source":["# --- 設定 ---\n","OUTPUT_DIR = \"/content/drive/MyDrive/hioki_lab/data/URMP_solo_inst/processed_data/\"  # .ptファイルが保存されているディレクトリ\n","SR = 16000                   # サンプリングレート (URMPに合わせて調整してください)\n","N_FFT = 1024\n","HOP_LENGTH = 256\n","N_MELS = 64\n","LOUDNESS_THRESHOLD = -60.0   # 無音区間を除外するための閾値 (dB)\n","margin_size = [3,30] # hpssのmarginサイズ設定"],"metadata":{"id":"nX2vanLjPEGU"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["## evaluate_latent_space：潜在空間の評価\n","異なるmarginで抽出したZについて、k_NN識別機とシルエットスコアを用いてどちらがより楽器の特徴をとらえているかを見るための関数"],"metadata":{"id":"ZLwT6r1gH6Zu"}},{"cell_type":"code","source":["import numpy as np\n","from sklearn.neighbors import KNeighborsClassifier\n","from sklearn.model_selection import cross_val_score\n","from sklearn.metrics import silhouette_score\n","from sklearn.preprocessing import StandardScaler\n","\n","def evaluate_latent_space(X, y, margin):\n","    \"\"\"\n","    X: 抽出された z_noise の配列 [N_samples, 192]\n","    y: 楽器のラベル配列 [N_samples]\n","    \"\"\"\n","    # 1. データの標準化 (PCA前や距離計算前のお約束)\n","    scaler = StandardScaler()\n","    X_scaled = scaler.fit_transform(X)\n","\n","    # 2. k-NN 識別精度 (k=5, 5分割交差検証)\n","    knn = KNeighborsClassifier(n_neighbors=5)\n","    # accuracy (正解率) を計算\n","    scores = cross_val_score(knn, X_scaled, y, cv=5, scoring='accuracy')\n","    mean_acc = np.mean(scores)\n","\n","    # 3. シルエットスコアの計算\n","    # (計算コストを下げるため、ラベルが同じもの同士の凝集度を見る)\n","    sil_score = silhouette_score(X_scaled, y)\n","    print(f\"Classification score margin = {margin}\")\n","    print(f\"k-NN Classification Accuracy: {mean_acc:.2%} (+/- {np.std(scores):.2%})\")\n","    print(f\"Silhouette Score: {sil_score:.4f}\")\n","\n","    return mean_acc, sil_score\n"],"metadata":{"id":"m9w0fK7zA0y1","executionInfo":{"status":"ok","timestamp":1770804412014,"user_tz":-540,"elapsed":83,"user":{"displayName":"ぽっとでひーろー","userId":"00322240631455561966"}}},"execution_count":24,"outputs":[]},{"cell_type":"markdown","source":["## extract_noise_params\n","ノイズのパラメータを線形回帰で抽出するための関数"],"metadata":{"id":"rfYRDwSoIm_O"}},{"cell_type":"code","execution_count":25,"metadata":{"id":"_arAro57aKa4","executionInfo":{"status":"ok","timestamp":1770804413601,"user_tz":-540,"elapsed":20,"user":{"displayName":"ぽっとでひーろー","userId":"00322240631455561966"}}},"outputs":[],"source":["import os\n","import glob\n","import torch\n","import librosa\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from sklearn.decomposition import PCA\n","from tqdm import tqdm\n","\n","\n","def extract_physics_noise_params(audio, loudness_curve, margin_option, sr=SR):\n","    \"\"\"\n","    音声とLoudnessから、物理的なノイズパラメータ(alpha, beta, sigma^2)を抽出する\n","    \"\"\"\n","    # 1. HPSSでノイズ成分(残差/Percussive)を抽出\n","    # audio: torch tensor -> numpy\n","    y = audio.numpy() if isinstance(audio, torch.Tensor) else audio\n","\n","    # marginを大きめにすることで、倍音の漏れを防ぎ、純粋なノイズを取り出す\n","    # y_harmonic, y_percussive = librosa.effects.hpss(y, margin=3.0)\n","    # ※ librosaのhpssは遅い場合があるので、重い場合はstftベースの実装に切り替えてください\n","    _, y_noise = librosa.effects.hpss(y, margin=margin_option)\n","\n","    # 2. ノイズ成分のLog-Melスペクトログラムを計算\n","    # ノイズ成分のSTFT\n","    S = librosa.stft(y_noise, n_fft=N_FFT, hop_length=HOP_LENGTH)\n","    # Melフィルタバンク\n","    mel_S = librosa.feature.melspectrogram(S=np.abs(S)**2, sr=sr, n_mels=N_MELS)\n","    # Log変換 (dB)\n","    log_mel_noise = librosa.power_to_db(mel_S, ref=np.max) # Shape: [n_mels, Time]\n","\n","    # 3. LoudnessとMelスペクトルの時間軸合わせ\n","    # .pt内のloudnessとここで計算したmelのフレーム数が微妙にずれる可能性があるため補間する\n","    n_frames = log_mel_noise.shape[1]\n","\n","    # loudness_curveをnumpy化\n","    loudness = loudness_curve.numpy() if isinstance(loudness_curve, torch.Tensor) else loudness_curve\n","    loudness = np.squeeze(loudness)\n","\n","    # LoudnessをMelスペクトルのフレーム数に合わせてリサンプリング(補間)\n","    original_steps = np.linspace(0, 1, len(loudness))\n","    target_steps = np.linspace(0, 1, n_frames)\n","    loudness_resampled = np.interp(target_steps, original_steps, loudness)\n","\n","    # 4. 線形回帰 (Vectorized Linear Regression)\n","    # 無音区間はノイズの挙動が不安定なため除外する\n","    mask = loudness_resampled > LOUDNESS_THRESHOLD\n","\n","    if np.sum(mask) < 10: # 有効なフレームが少なすぎる場合はゼロベクトルを返す\n","        return np.zeros(N_MELS*3)\n","\n","    X = loudness_resampled[mask]   # [T_active]\n","    Y = log_mel_noise[:, mask]     # [n_mels, T_active]\n","\n","    # 平均を引く（中心化）\n","    X_mean = np.mean(X)\n","    Y_mean = np.mean(Y, axis=1, keepdims=True)\n","\n","    X_centered = X - X_mean\n","    Y_centered = Y - Y_mean\n","\n","    # 傾き alpha (Slope): Cov(X, Y) / Var(X)\n","    # 分母: Var(X) * N\n","    denominator = np.dot(X_centered, X_centered) + 1e-6\n","    # 分子: Cov(X, Y) * N (ドット積で行ける)\n","    numerator = np.dot(Y_centered, X_centered)\n","\n","    alpha = numerator / denominator # [n_mels]\n","\n","    # 切片 beta (Intercept): Y_mean - alpha * X_mean\n","    beta = Y_mean.flatten() - alpha * X_mean # [n_mels]\n","\n","    # 予測値と残差分散 sigma^2 (Residual Variance)\n","    # Y_pred = alpha * X + beta\n","    # shape合わせ: alpha[n_mels, 1] * X[1, T] + beta[n_mels, 1]\n","    Y_pred = np.outer(alpha, X) + beta[:, np.newaxis]\n","    Residuals = Y - Y_pred\n","    sigma_sq = np.var(Residuals, axis=1) # [n_mels]\n","\n","    # 5. 結合して1つのベクトルにする\n","    # [alpha(64), beta(64), sigma(64)] -> 192次元\n","    z_noise = np.concatenate([alpha, beta, sigma_sq])\n","\n","    return z_noise\n","\n"]},{"cell_type":"markdown","source":["## PCAによる可視化コード"],"metadata":{"id":"YGzyeT_5JiwZ"}},{"cell_type":"code","source":["def pca(X,y,margin):\n","    # --- PCAによる可視化 ---\n","    print(\"Running PCA...\")\n","    pca = PCA(n_components=2)\n","    X_pca = pca.fit_transform(X)\n","\n","    # 寄与率の確認\n","    print(f\"Explained Variance Ratio: {pca.explained_variance_ratio_}\")\n","    print(f\"Cumulative: {np.sum(pca.explained_variance_ratio_)}\")\n","\n","    # プロット\n","    plt.figure(figsize=(10, 8))\n","    unique_labels = np.unique(y)\n","\n","    for label in unique_labels:\n","        indices = np.where(y == label)\n","        plt.scatter(X_pca[indices, 0], X_pca[indices, 1], label=label, alpha=0.7, s=20)\n","\n","    plt.title(f\"PCA of Physics-Informed Noise Latent Space (N={len(X)})\")\n","    plt.xlabel(f\"PC1 (Gain/Energy?) - {pca.explained_variance_ratio_[0]:.2%} var\")\n","    plt.ylabel(f\"PC2 (Slope/Sensitivity?) - {pca.explained_variance_ratio_[1]:.2%} var\")\n","    plt.legend()\n","    plt.grid(True, alpha=0.3)\n","\n","    # 結果を保存\n","    plt.savefig(f\"z_noise_pca_margin={margin}.png\")\n","    print(\"Plot saved to z_noise_pca.png\")\n","\n","    # 固有ベクトルの意味を解釈するために保存\n","    # (どの周波数帯域が効いているか、alpha/beta/sigmaどれが重要か)\n","    np.save(f\"pca_components_margin={margin}.npy\", pca.components_)\n","    np.save(f\"pca_mean_margin={margin}.npy\", pca.mean_)\n","    print(\"PCA components saved.\")"],"metadata":{"id":"hPaWMOrsJiYn","executionInfo":{"status":"ok","timestamp":1770804743334,"user_tz":-540,"elapsed":19,"user":{"displayName":"ぽっとでひーろー","userId":"00322240631455561966"}}},"execution_count":28,"outputs":[]},{"cell_type":"markdown","source":["## main\n","・各marginごとに得られたZについてPCAを行う。\n","・結果を散布図に出力（縦軸と横軸は寄与率の高い二軸）\n","・k_NNとシルエット"],"metadata":{"id":"uPA-vn4CIysL"}},{"cell_type":"code","source":["def main():\n","    pt_files = glob.glob(os.path.join(OUTPUT_DIR, \"*.pt\"))\n","    if not pt_files:\n","        print(\"No .pt files found.\")\n","        return\n","\n","\n","\n","    for i in range(len(margin_size)):\n","      z_vectors = []\n","      labels = []\n","\n","      print(f\"Extracting features...margin = {margin_size[i]}\")\n","      for fpath in tqdm(pt_files):\n","          try:\n","              data = torch.load(fpath)\n","\n","              # データの読み出し\n","              audio = data['audio']          # 元音源\n","              loudness = data['loudness']    # A-weighted loudness\n","              instrument = data['instrument_name'] # 楽器名ラベル\n","\n","              # 特徴抽出\n","              z = extract_physics_noise_params(audio, loudness, margin_size[i])\n","\n","              # エラー処理（無音ファイルなど）\n","              if np.all(z == 0):\n","                  continue\n","\n","              z_vectors.append(z)\n","              labels.append(instrument)\n","\n","          except Exception as e:\n","              print(f\"Error processing {fpath}: {e}\")\n","              continue\n","\n","      if not z_vectors:\n","          print(\"No valid features extracted.\")\n","          return\n","\n","      # numpy配列化\n","      X = np.array(z_vectors) # [N_samples, 192]\n","      y = np.array(labels)\n","      pca(X,y,margin_size[i])\n","      evaluate_latent_space(X, y, margin_size[i])\n","\n","if __name__ == \"__main__\":\n","    main()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"ii9o2Ba0Ixya","executionInfo":{"status":"ok","timestamp":1770805200109,"user_tz":-540,"elapsed":453748,"user":{"displayName":"ぽっとでひーろー","userId":"00322240631455561966"}},"outputId":"ed29298a-e53c-440b-e574-443b3707fb1f"},"execution_count":29,"outputs":[{"output_type":"stream","name":"stdout","text":["Extracting features...margin = 3\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 968/968 [03:48<00:00,  4.24it/s]\n"]},{"output_type":"stream","name":"stdout","text":["Running PCA...\n","Explained Variance Ratio: [0.56137802 0.15063429]\n","Cumulative: 0.7120123073665064\n","Plot saved to z_noise_pca.png\n","PCA components saved.\n","Classification score margin = 3\n","k-NN Classification Accuracy: 77.79% (+/- 5.43%)\n","Silhouette Score: 0.0437\n","Extracting features...margin = 30\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 968/968 [03:42<00:00,  4.35it/s]\n"]},{"output_type":"stream","name":"stdout","text":["Running PCA...\n","Explained Variance Ratio: [0.52817754 0.20377248]\n","Cumulative: 0.7319500237154366\n","Plot saved to z_noise_pca.png\n","PCA components saved.\n","Classification score margin = 30\n","k-NN Classification Accuracy: 67.15% (+/- 4.24%)\n","Silhouette Score: -0.0152\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x800 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x800 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import torch\n","import librosa\n","import soundfile as sf\n","import numpy as np\n","\n","# --- 設定 ---\n","TARGET_PT_FILE = file_path # 聞いてみたい.ptファイルのパス\n","OUTPUT_WAV_PATH = \"noise_only_check.wav\"       # 保存するファイル名\n","MARGIN =1.0  # HPSSの分離強度（1.0だと甘め、3.0以上だと厳しめ）\n","\n","def save_noise_component():\n","    print(f\"Loading {TARGET_PT_FILE}...\")\n","    try:\n","        data = torch.load(TARGET_PT_FILE)\n","        audio = data['audio'].numpy()\n","\n","        # もしステレオならモノラルにする（librosaは基本モノラル推奨）\n","        if len(audio.shape) > 1:\n","             audio = np.mean(audio, axis=0)\n","\n","        # HPSS実行\n","        # margin: 倍音とノイズの境界をどれくらい厳しくするか。\n","        # marginが大きいほど「倍音」判定が厳しくなり、ノイズ側に倍音が漏れにくくなります。\n","        y_harmonic, y_noise = librosa.effects.hpss(audio, margin=MARGIN)\n","\n","        # 保存\n","        # そのまま保存すると音が小さいことがあるので、正規化（最大音量化）しても良いですが、\n","        # ノイズの「本来の小ささ」を知るためには正規化しない方が物理的に正しいです。\n","        # ここでは聞きやすさ優先で、少しブーストして保存します。\n","\n","        # normalize=Falseのまま保存（物理的に正しい音量）\n","        sf.write(OUTPUT_WAV_PATH, y_noise, 16000)\n","\n","        print(f\"Saved noise component to: {OUTPUT_WAV_PATH}\")\n","        print(\"このファイルを再生して確認してください。\")\n","\n","    except Exception as e:\n","        print(f\"Error: {e}\")\n","\n","if __name__ == \"__main__\":\n","    save_noise_component()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LH7x0Q86k2qN","executionInfo":{"status":"ok","timestamp":1770729668270,"user_tz":-540,"elapsed":658,"user":{"displayName":"ぽっとでひーろー","userId":"00322240631455561966"}},"outputId":"c116305a-a2ff-4870-c895-bab97b8ce16c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading /content/drive/MyDrive/hioki_lab/data/URMP_solo_inst/processed_data/cl_AuSep_1_cl_19_Pavane_012.pt...\n","Saved noise component to: noise_only_check.wav\n","このファイルを再生して確認してください。\n"]}]},{"cell_type":"markdown","source":["## ノイズが保持している情報について観察\n","・SFM（スペクトル平坦度）：出力されたノイズがどれだけホワイトノイズらしいか\n","※平坦な形になっており、倍音構造などの規則性が見られないことの確認のために入れたが、hpssのmarginを30にしても値は0.14程度であり、低い水準を保ったままだった。そりゃそうで、ノイズにも規則性は残っているだろうという話。あまり意味のない指標かもしれない\n","\n","・ノイズのオンセット相関\n","ノイズの立ち上がりなどが、もとの音源と比べてどの程度保持されているかの相関を見る。これはmarginを大きくするほどアタック音が削られることで小さくなっていく。\n","実際にmargin = 3のときには0.8程度だったが、margin=30では0.7を下回った\n"],"metadata":{"id":"O9clR-xqK-0L"}},{"cell_type":"code","source":["import librosa\n","import numpy as np\n","import torch\n","import glob\n","import os\n","from sklearn.metrics import silhouette_score\n","from sklearn.decomposition import PCA\n","\n","# --- 設定 ---\n","OUTPUT_DIR = \"/content/drive/MyDrive/hioki_lab/data/URMP_solo_inst/processed_data/\"  # .ptファイルが保存されているディレクトリ\n","SR = 16000                   # サンプリングレート (URMPに合わせて調整してください)\n","N_FFT = 1024\n","HOP_LENGTH = 256\n","N_MELS = 64\n","LOUDNESS_THRESHOLD = -60.0   # 無音区間を除外するための閾値 (dB)\n","\n","# --- 比較設定 ---\n","MARGINS = [10.0, 20.0, 30.0]\n","FILES = glob.glob(os.path.join(OUTPUT_DIR, \"*.pt\"))\n","if not FILES:\n","    print(\"No .pt files found.\")\n","\n","def evaluate_margin(margin, files):\n","    sfm_scores = []\n","    onset_corrs = []\n","\n","    z_vectors = []\n","    labels = []\n","\n","    print(f\"--- Testing Margin = {margin} ---\")\n","\n","    for fpath in files:\n","        data = torch.load(fpath)\n","        y = data['audio'].numpy().squeeze()\n","        if y.ndim > 1: y = np.mean(y, axis=0)\n","\n","        # 1. HPSS実行\n","        y_harm, y_noise = librosa.effects.hpss(y, margin=margin)\n","\n","        # --- 指標A: スペクトル平坦度 (Noiseらしさ) ---\n","        # ノイズ成分の平坦度を計算 (高いほど良い)\n","        flatness = librosa.feature.spectral_flatness(y=y_noise)\n","        sfm_scores.append(np.mean(flatness))\n","\n","        # --- 指標B: オンセット相関 (アタック保存率) ---\n","        # 元音声のオンセット強度\n","        onset_env_orig = librosa.onset.onset_strength(y=y, sr=16000)\n","        # ノイズ音声のオンセット強度\n","        onset_env_noise = librosa.onset.onset_strength(y=y_noise, sr=16000)\n","\n","        # 相関を計算 (長さが微妙に違うことがあるので合わせる)\n","        min_len = min(len(onset_env_orig), len(onset_env_noise))\n","        corr = np.corrcoef(onset_env_orig[:min_len], onset_env_noise[:min_len])[0, 1]\n","        onset_corrs.append(corr)\n","\n","        # --- 特徴量抽出 (PCA用) ---\n","        # (先ほどのextract_physics_noise_params関数の中身と同じ処理を行い z を取得)\n","        # ※ ここでは簡略化のため省略しますが、先ほどの関数を使って z を取得してください\n","        # z = extract_physics_noise_params(torch.tensor(y), data['loudness'])\n","        # z_vectors.append(z)\n","        # labels.append(data['instrument'])\n","\n","    avg_sfm = np.mean(sfm_scores)\n","    avg_corr = np.mean(onset_corrs)\n","\n","    print(f\"Margin {margin}:\")\n","    print(f\"  Avg Spectral Flatness (Whiteness): {avg_sfm:.4f}\")\n","    print(f\"  Avg Onset Correlation (Attack):    {avg_corr:.4f}\")\n","\n","    return avg_sfm, avg_corr\n","\n","# 実行\n","r3 = evaluate_margin(10.0, FILES)\n","r5 = evaluate_margin(30.0, FILES)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"tPIjzEn-5nd0","executionInfo":{"status":"ok","timestamp":1770801792878,"user_tz":-540,"elapsed":482949,"user":{"displayName":"ぽっとでひーろー","userId":"00322240631455561966"}},"outputId":"57dbaa7f-23d4-4afd-963d-fdd72915109d"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Testing Margin = 10.0 ---\n","Margin 10.0:\n","  Avg Spectral Flatness (Whiteness): 0.0149\n","  Avg Onset Correlation (Attack):    0.7438\n","--- Testing Margin = 30.0 ---\n","Margin 30.0:\n","  Avg Spectral Flatness (Whiteness): 0.1438\n","  Avg Onset Correlation (Attack):    0.6866\n"]}]},{"cell_type":"code","source":["print(f\"データ型: {type(data)}\")\n","print(f\"キー: {data.keys()}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"8_FhZ9cceJ2Y","executionInfo":{"status":"ok","timestamp":1770729590319,"user_tz":-540,"elapsed":14,"user":{"displayName":"ぽっとでひーろー","userId":"00322240631455561966"}},"outputId":"650e67c5-e82a-4ef8-ed9e-2071af38456a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["データ型: <class 'dict'>\n","キー: dict_keys(['audio', 'mel', 'f0', 'loudness', 'instrument_name'])\n"]}]}]}